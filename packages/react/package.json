{
  "name": "pd-dynamic-form-react",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --clean --external react --external pd-dynamic-form",
    "dev": "tsup src/index.tsx --format cjs,esm --watch --dts --external react --external pd-dynamic-form",
    "test": "vitest run",
    "lint": "eslint src/**/*.{ts,tsx} --no-error-on-unmatched-pattern"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "lucide-react": "^0.300.0",
    "pd-dynamic-form": "workspace:*",
    "tailwind-merge": "^2.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^22.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
